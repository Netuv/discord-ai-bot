{
    "name": "Discord AI Bot",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
    "postCreateCommand": "npm install && npm run cf-typegen",
    "postStartCommand": "bash .devcontainer/startup.sh",
    "forwardPorts": [
        8787,
        9999
    ],
    "portsAttributes": {
        "8787": {
            "label": "Wrangler Dev",
            "onAutoForward": "notify"
        },
        "9999": {
            "label": "Command Server",
            "onAutoForward": "openBrowser"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "cloudflare.cloudflare-workers"
            ]
        }
    }
}
{
	"name": "Discord AI Bot",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:22",
	"postCreateCommand": "npm install && npm run cf-typegen",
	"forwardPorts": [8787],
	"portsAttributes": {
		"8787": {
			"label": "Wrangler Dev",
			"onAutoForward": "notify"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"cloudflare.cloudflare-workers",
				"dbaeumer.vscode-eslint"
			]
		}
	}
}
